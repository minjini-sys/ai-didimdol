# Copy this file to .env and fill in one provider.

# Provider: fallback | openai | gemini | ollama
LLM_PROVIDER=fallback

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Local Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

# Dynamic Registry Search
# false: 내장 Registry만 사용
# true: GitHub에서 Skill/MCP/Agent 후보를 실시간 검색하고 검증 후보로 표시
DYNAMIC_REGISTRY=false
DYNAMIC_REGISTRY_LIMIT=3
DYNAMIC_REGISTRY_PER_QUERY=3
DYNAMIC_REGISTRY_MAX_QUERIES=3
DYNAMIC_REGISTRY_MIN_TRUST=35
DYNAMIC_REGISTRY_TIMEOUT_MS=3500
GITHUB_TOKEN=

# Server
PORT=3000

